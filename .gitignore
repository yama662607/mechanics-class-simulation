# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# =============================================================================
# Node
# =============================================================================
node_modules/

# =============================================================================
# Quarto
# =============================================================================
# Build output (output-dir = _book per Quarto official recommendation)
quarto/_book/
quarto/.quarto/
.quarto/
quarto/**/*.html
quarto/**/*_files/
!quarto/templates/**/*.html

# NOTE: quarto/_freeze/ is intentionally NOT ignored.
# Commit it so CI does not re-execute Python/R compute blocks on every push.
# (Quarto official guidance: https://quarto.org/docs/projects/code-execution.html#freeze)

# =============================================================================
# LaTeX build artifacts
# =============================================================================
quarto/*.aux
quarto/*.log
quarto/*.tex
!quarto/preamble.tex
quarto/*.toc
quarto/*.pdf

# =============================================================================
# Research / private source material (raw lecture PDFs, scans, etc.)
# Keep .gitkeep placeholders so directories are tracked.
# =============================================================================
quarto/assets/raw/*
quarto/assets/private/*
!quarto/assets/raw/.gitkeep
!quarto/assets/private/.gitkeep

research/inbox/*/
research/inbox/*
!research/inbox/.gitkeep
!research/inbox/manifest.yml

# =============================================================================
# Tool caches
# =============================================================================
tools/.validation_cache.json

# =============================================================================
# OS / Editor
# =============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
.data/
.playwright-mcp/

# =============================================================================
# AI agent local config
# =============================================================================
.codex/
.gemini/
.claude/
CLAUDE.local.md
